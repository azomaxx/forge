---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Build .NET security tools with GitHub Actions" } = Astro.props;
const contributors = [
  {
    name: "Shadow21AR",
    role: "Contributor",
    avatar:
      "https://cdn.discordapp.com/avatars/960119774526988348/6cf05d2bd1ccc5ae69769b8911c84bc0.png?size=512",
  },
  {
    name: "Azomax",
    role: "Contributor",
    avatar:
      "https://cdn.discordapp.com/avatars/147398098967199745/a78f63c93e499c9b8595b2c338387efb.png?size=512",
  },
];
const pathname = Astro.url.pathname;
const url = Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content="dotnet, security, tools, build, github actions, pentest, red team, .NET" />
    <meta name="author" content="Shadow21AR, Azomaxx" />
    <meta name="robots" content="index, follow" />
    
    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Forge" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@Shafow21A" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://raw.githubusercontent.com/Shadow21AR/forge/main/public/favicon.png" />
    <meta property="og:image" content="https://raw.githubusercontent.com/Shadow21AR/forge/main/public/favicon.png" />
    <meta property="og:image:width" content="200" />
    <meta property="og:image:height" content="200" />
    
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="https://raw.githubusercontent.com/Shadow21AR/forge/main/public/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="https://raw.githubusercontent.com/Shadow21AR/forge/main/public/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="https://raw.githubusercontent.com/Shadow21AR/forge/main/public/apple-touch-icon.png" />
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div class="topbar-left">
          <a class="brand" href="/">
            <span class="brand-mark">F</span>
            <span class="brand-copy">
              <strong>forge</strong>
              <span>.NET build console</span>
            </span>
          </a>
          <nav class="nav-links" id="nav">
            <span class="nav-indicator"></span>
            <a href="/" class={pathname === "/" ? "active" : ""}>Build</a>
            <a href="/results" class={pathname.startsWith("/results") ? "active" : ""}>Results</a>
            <a href="/runs" class={pathname.startsWith("/runs") ? "active" : ""}>Runs</a>
          </nav>
        </div>
        <div class="topbar-right">
        </div>
      </header>
      <slot />
      <footer class="creator-bar">
        {contributors.map((contributor) => (
          <div class="creator-card">
            <img src={contributor.avatar} alt={`${contributor.name} avatar`} loading="lazy" />
            <div>
              <strong>{contributor.name}</strong>
              <span>{contributor.role}</span>
            </div>
          </div>
        ))}
        <a href="https://github.com/Shadow21AR/forge" target="_blank" rel="noopener" class="repo-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
          View source
        </a>
      </footer>
    </main>
    <script is:inline>
      (function() {
        var nav = document.getElementById('nav');
        if (!nav) return;
        
        var indicator = nav.querySelector('.nav-indicator');
        var links = nav.querySelectorAll('a');
        var active = nav.querySelector('a.active') || links[0];
        
        function moveIndicator() {
          if (!indicator || !active) return;
          indicator.style.left = active.offsetLeft + 'px';
          indicator.style.width = active.offsetWidth + 'px';
        }
        
        // Delay initial position to ensure smooth animation
        setTimeout(moveIndicator, 100);
        window.addEventListener('resize', moveIndicator);
        
        links.forEach(function(link) {
          link.addEventListener('click', function() {
            active = link;
            moveIndicator();
          });
        });
      })();
    </script>
  </body>
</html>
